{
  "expo": {
    "name": "Cosmic Help",
    "slug": "cosmic-help",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "cosmichelp",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a16"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cosmichelp.app",
      "buildNumber": "7",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cosmic Help uses the camera to let you capture images for personal reflection.",
        "NSPhotoLibraryUsageDescription": "Cosmic Help needs access to your photos so you can choose images for reflection.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0a0a16"
      },
      "package": "com.cosmichelp.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Cosmic Help to access your camera for AI analysis."
        }
      ],
      "expo-apple-authentication"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "01bded58-ceef-47b9-8d47-d92b956f1a71"
      }
    },
    "owner": "melihagraz"
  }
}
